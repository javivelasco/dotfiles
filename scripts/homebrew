#!/bin/bash

set -e

ROOT_DIRECTORY="$(cd "$(dirname "$0")/.." && pwd)"
BREWFILE="$ROOT_DIRECTORY/brew/.Brewfile"

if ! command -v brew &> /dev/null; then
  echo " --> Installing Homebrew"
  bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  # Make brew available in this shell (Apple Silicon / Intel)
  if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
else
  echo " --> Homebrew exists!"
fi

# Trust every third-party tap declared in the Brewfile (required since
# Homebrew introduced trusted taps; safe to re-run)
grep '^tap "' "$BREWFILE" | awk -F'"' '{print $2}' | while read -r tap; do
  brew trust "$tap" 2>/dev/null || true
done

echo " --> Installing Brewfile from $BREWFILE"
brew bundle check "--file=$BREWFILE" || brew bundle install "--file=$BREWFILE"

# Make fish the default shell
FISH_PATH="$(command -v fish || true)"
if [ -z "$FISH_PATH" ]; then
  echo " --> WARNING: fish not found, skipping default shell setup"
else
  if ! grep -q "$FISH_PATH" /etc/shells; then
    echo " --> Adding $FISH_PATH to /etc/shells (requires sudo)"
    echo "$FISH_PATH" | sudo tee -a /etc/shells > /dev/null
  fi

  if [ "$SHELL" != "$FISH_PATH" ]; then
    echo " --> Setting fish as the default shell"
    chsh -s "$FISH_PATH"
  else
    echo " --> fish is already the default shell"
  fi
fi

echo " --> Done!"
